# Database URL for Prisma (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Admin panel — set the same values in Vercel → Project → Settings → Environment Variables
# Email and phone must match exactly what you enter on login (phone accepts +91 or 10 digits).
ADMIN_EMAIL="admin@example.com"
ADMIN_PHONE="000000000000"
ADMIN_SECRET="generate-a-long-random-secret-for-production"

# WhatsApp OTP (customer login)
OTP_SECRET="your-otp-signing-secret"
AISENSY_API_KEY=""
AISENSY_CAMPAIGN_NAME="minaliyaloginotp"
AISENSY_USER_NAME="Minaliya Goods And Services"

